{
  "name": "memorable-passwords",
  "private": true,
  "description": "Memorable password generator — monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @memorable-passwords/core build",
    "build:extension": "pnpm --filter @memorable-passwords/extension build",
    "dev": "pnpm --filter @memorable-passwords/extension dev",
    "dev:core": "pnpm --filter @memorable-passwords/core dev",
    "demo": "vite --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --force",
    "icons": "node scripts/generate-icons.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}